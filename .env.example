# Apex Environment Configuration
# Copy this file to .env and fill in the values.

# Database
DB_PASSWORD=apex

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_PASSWORD=guest

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Frontend
FRONTEND_ORIGIN=http://localhost:5173

# CoinGecko (optional, for live market data)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# Gemini AI Journal (free tier via Google AI Studio: https://aistudio.google.com)
# Provides AI-powered trade journal narratives. Free tier has generous limits.
GEMINI_API_KEY=
