# Database (PostgreSQL 16)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=apex
DB_USER=apex
DB_PASSWORD=apex

# Redis 7
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Anthropic API (for AI trade journal generation)
ANTHROPIC_API_KEY=your-key-here

# Docker (Windows local dev only — needed for Testcontainers to bypass broken named pipes on Docker Desktop 29.x.
# NOT needed on Linux/macOS or CI, which use the standard Docker socket.
# After setting, run: setx DOCKER_HOST tcp://localhost:2375 and open a fresh terminal.)
# DOCKER_HOST=tcp://localhost:2375
